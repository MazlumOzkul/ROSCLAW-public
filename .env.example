# API Anahtarlari - .env.example bir SABLONDUR, gercek anahtarlarini
# buraya YAZMA. Bu dosyayi ".env" olarak kopyala, sonra kendi degerlerini gir.
# ".env" .gitignore'da - asla git'e eklenmez.
ANTHROPIC_API_KEY=your_claude_api_key_here
OLLAMA_BASE_URL=http://localhost:11434
ROSCLAW_ENV=development

# Robot baglantisi - varsayilan olarak Gazebo simulasyonuna (WSL2/rosbridge)
# isaret eder. Gercek bir robota gecince SADECE bu iki degeri robotun
# IP/portuyla degistir - kodda hicbir sey degismesine gerek yok.
ROS2_HOST=localhost
ROS2_PORT=9090
